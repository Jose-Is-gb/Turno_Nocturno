  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a8b868ec9315aa141ab8a5dce63533cf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NotaInteractiva
  panelNota: {fileID: 38649948}
  componenteTexto: {fileID: 1861006039}
  textoDeLaHistoria: "Instrucciones para el turno nocturno:\r\n\r\n1- Si algo se
    mueve en las salas, rep\xF3rtalo en  la bit\xE1cora.\r\n2- Si sientes que algo
    te observa desde los cuadros, no lo mires demasiado tiempo.\r\n3- Si escuchas
    que dicen tu nombre, bajo ning\xFAn motivo respondas.\r\n4- Si decides esconderte...
    guarda silencio absoluto.\r\nBienvenido al Museo del Silencio, Daniel."
